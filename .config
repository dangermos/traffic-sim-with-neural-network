# Evolution training settings (key=value)
rng_seed=42

# Level/map selection
# Easy:   straight_line, straight_road, level1, level2, level3
# Medium: test_sensors, overnight (city grid)
# Hard:   nightmare (twisty), nightmare_extreme (brutal)
level=nightmare

# Neural network topology (comma-separated layer sizes)
# First = inputs (5 for car sensors), Last = outputs (2 for throttle/steering)
# Middle = hidden layers. More/larger hidden layers = more complex behavior
# Examples:
#   5,8,2      = simple (5 inputs, 8 hidden, 2 outputs) - 58 genes
#   5,12,8,2   = medium (two hidden layers) - 170 genes
#   5,16,16,2  = complex (two larger hidden layers) - 370 genes
topology=5,8,2

epochs=100
max_frames=2000
elitism=2
mutation_rate=0.7
mutation_strength=0.3
tournament_size=2
enable_early_exit=false
stall_distance=5.0
stall_frames=200
print_every=10
checkpoint_every=100

# Island parallelism
num_islands=4
migration_interval=25
migration_count=1

# Population-Based Training (auto-tune hyperparameters)
pbt_enabled=false
pbt_interval=25

# Simulation feature toggles (for testing/benchmarking)
# Disable these to see how they affect evolution dynamics
enable_collisions=true
enable_occlusion=true

# Population size override
# Set to 0 to use the level's default (based on CARS_PER_ROAD in level code)
# Set to a positive number to override with a custom population size
# Recommended: 200-400 for meaningful evolution, 50+ per island minimum
# Example: with num_islands=4 and population_size=400, you get 100 cars per island
population_size=400

# Fitness function parameters
# Tune these to change selection pressure and evolutionary dynamics
# All values shown are defaults - uncomment and modify to experiment

# Rewards
destination_bonus=100.0        # Base bonus for reaching goal
speed_bonus_max=150.0          # Additional bonus for reaching fast
proximity_reward=50.0          # Reward for ending close to goal (if not reached)
road_adherence_reward=30.0     # Reward for staying on road
# Penalties
off_road_penalty=50.0          # Penalty for going off road
crash_penalty_mult=0.2         # Multiplicative penalty for crashing (keeps 20%)
stagnant_penalty=40.0          # Penalty for stagnating/stopping
idle_penalty=20.0              # Penalty for not moving at all

# Timing
expected_completion_time=1500.0  # Reference time for speed bonus calculation
