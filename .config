# Evolution training settings (key=value)
rng_seed=42

# Level/map selection
# Easy:   straight_line, straight_road, level1, level2, level3
# Medium: test_sensors, overnight (city grid)
# Hard:   nightmare (twisty), nightmare_extreme (brutal)
level=nightmare

# Neural network topology (comma-separated layer sizes)
# First = inputs (5 for car sensors), Last = outputs (2 for throttle/steering)
# Middle = hidden layers. More/larger hidden layers = more complex behavior
# Examples:
#   5,8,2      = simple (5 inputs, 8 hidden, 2 outputs) - 58 genes
#   5,12,8,2   = medium (two hidden layers) - 170 genes
#   5,16,16,2  = complex (two larger hidden layers) - 370 genes
topology=5,32,64,32,32,16,16,8,8,4,4,2
epochs=100
max_frames=500
elitism=4
mutation_rate=0.7
mutation_strength=0.3
tournament_size=3
enable_early_exit=false
stall_distance=5.0
stall_frames=200
print_every=10
checkpoint_every=100

# Island parallelism
num_islands=10
migration_interval=5
migration_count=3

# Population-Based Training (auto-tune hyperparameters)
pbt_enabled=true
pbt_interval=5
